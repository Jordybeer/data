# Magic-link session cookie signing key
# Generate with: openssl rand -base64 32
AUTH_SECRET=generate_with_openssl_rand_base64_32

# Admin email that is allowed to sign in
ADMIN_EMAIL=contact@jordy.beer

# Public URL used to build magic-link URLs
NEXTAUTH_URL=http://localhost:3000

# Supabase (server-side + browser-read clients)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# SMTP for magic-link delivery (any provider: Mailgun, SES, Fastmail, Gmail app password, self-hosted, etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=postmaster@example.com
SMTP_PASS=your_password
SMTP_FROM="Psychonaut DB <no-reply@example.com>"
